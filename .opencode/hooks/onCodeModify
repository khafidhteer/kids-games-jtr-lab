#!/bin/bash

echo "🔄 OpenCode modification detected. Running cache-busting version bump..."

# Your version bump command
TS=$(date -u +%Y%m%d%H%M%S)
find . -path './.agents' -prune -o \( -name '*.html' -o -name 'js/version.js' \) -print | xargs sed -i "s/v=[0-9]*/v=${TS}/g"

echo "✅ Version timestamp updated to v=${TS}"
